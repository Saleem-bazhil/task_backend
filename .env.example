# Required
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key
DATABASE_URL=postgres://user:password@localhost:5432/dbname

# Optional
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_TIME_ZONE=UTC

# CORS / CSRF (comma-separated origins)
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
# CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:8000

# S3 Storage (set AWS_STORAGE_BUCKET_NAME to activate)
# AWS_STORAGE_BUCKET_NAME=my-bucket-name
# AWS_S3_REGION_NAME=ap-south-1
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# AWS_S3_CUSTOM_DOMAIN=my-bucket-name.s3.ap-south-1.amazonaws.com

# Redis (required for WebSockets in production)
# REDIS_URL=redis://127.0.0.1:6379/0

# Cookie domains (for cross-domain setups)
# SESSION_COOKIE_DOMAIN=.example.com
# CSRF_COOKIE_DOMAIN=.example.com

# Logging
# DJANGO_LOG_LEVEL=WARNING
